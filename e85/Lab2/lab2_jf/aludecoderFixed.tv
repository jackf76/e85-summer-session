// ALU Decoder test vectors (Table 7.3)
// ALUOp funct3 op5 funct75 _ ALUControl
//  [1:0]  [2:0]  .   .     .   [2:0]
00_000_0_0_000   // lw/sw      -> add (000)
01_000_0_0_001   // beq        -> sub (001)
10_000_0_0_000   // addi       -> add (000)
10_000_1_0_000   // add  (R)   -> add (000)
10_000_1_1_001   // sub  (R)   -> sub (001)
10_010_0_0_101   // slt        -> set less than (101)
10_110_0_0_011   // or         -> or  (011)
10_111_0_0_010   // and        -> and (010)
